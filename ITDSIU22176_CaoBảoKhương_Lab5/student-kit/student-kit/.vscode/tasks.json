{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile Solver",
      "type": "shell",
      "command": "javac",
      "args": [
        "--release",
        "17",
        "-cp",
        "${workspaceFolder}/lib/micromouse-framework.jar",
        "-d",
        "${workspaceFolder}/out",
        "${workspaceFolder}/src/student/StudentSolverImpl.java"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$javac"
    }
  ]
}
